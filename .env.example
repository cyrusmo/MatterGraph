# Materials Project (https://www.materialsproject.org/) — 32-char key
# Preferred env name for `mp_api`:
MP_API_KEY=
# Legacy alias (also supported by MatterGraph connectors)
MATERIALS_PROJECT_API_KEY=

# Optional: JARVIS / NOMAD tokens if you use authenticated endpoints
JARVIS_API_KEY=
NOMAD_TOKEN=

# Demo API
MATTERGRAPH_API_HOST=0.0.0.0
MATTERGRAPH_API_PORT=8000
MATTERGRAPH_DEMO_DATA=data/demo/materials_sample.jsonl
